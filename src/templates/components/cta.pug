
dialog.popup.popup-center#ctaPopup
    .card.card-white.card-rounded.h-auto.overflow-hidden
        .popup__close
            button.btn.btn-primary-outline.btn-circle.btn-small(onclick="ctaPopup.close()")
                svg.d-block(width="16" height="16")
                    use(href="#close")
        h4.h6.text-center.text-uppercase.popup__title Napisz do nas — oddzwonimy do Ciebie!
        form#cta-form(method="POST")
            .row
                .col
                    input.input.cta__input.card.card-primary-outline.card-rounded.card-small(type="text" placeholder="Imię" name="name", required)
                .col
                    input.input.cta__input.card.card-primary-outline.card-rounded.card-small(type="tel" placeholder="Telefon" name="phone", required)
                .col
                    textarea.input.cta__input.card.card-primary-outline.card-rounded.card-small(placeholder="Wiadomość" name="message" rows="4")
                .col
                    button.btn.btn-primary.btn-normal.btn-pillow.cta__btn(type="submit") Wyślij zgłoszenie
button.cta-button.btn.btn-primary.btn-circle.btn-large.btn-pulse(onclick="ctaPopup.showModal()")
    span.sr-only Zostaw swoje dane, a skontaktujemy się z Tobą.
    svg.icon.shake(width="16" height="16")
        use(href="#tel")
dialog.popup.popup-center#popupCtaSuccess
    button.btn.btn-circle.btn-small.popup__close(onclick="popupCtaSuccess.close()")
        svg.d-block(width="16" height="16")
            use(href="#close")
    .card.card-third-outline.card-rounded.h-auto
        .text-center
            svg.d-block(width="48" height="48")
                use(href="#check")
        .text-center Twoja wiadomość została pomyślnie wysłana. Prosimy poczekać, aż nasz menedżer skontaktuje się z Tobą w celu uzgodnienia szczegółów.
dialog.popup.popup-center#popupCtaError
    button.btn.btn-circle.btn-small.popup__close(onclick="popupCtaSuccess.close()")
        svg.d-block(width="16" height="16")
            use(href="#close")
    .card.card-third-outline.card-rounded.h-auto
        .text-center
            svg.d-block(width="48" height="48")
                use(href="#error")
    .text-center Wystąpił błąd podczas wysyłania wiadomości.
