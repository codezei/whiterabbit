script(type="application/ld+json").
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "@id": "https://whiterabbitcleaning.pl/#faq",
        "url": "https://whiterabbitcleaning.pl/#faq",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "Як часто потрібно чистити м'які меблі?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Ми рекомендуємо проводити професійну хімчистку м'яких меблів кожні 6–12 місяців. Якщо вдома є діти, домашні тварини або люди, які страждають на алергію, варто робити це частіше."
                }
            },
            {
                "@type": "Question",
                "name": "Чи можна видалити всі плями?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Більшість плям можна успішно видалити, однак усе залежить від їхнього походження, давності та попередніх спроб очищення. Деякі дуже стійкі плями можуть залишити незначні сліди."
                }
            },
            {
                "@type": "Question",
                "name": "Скільки часу сохне оббивка після чищення?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Час висихання залежить від типу тканини та умов у приміщенні. Зазвичай це займає від 5 до 12 годин. За додаткову оплату можна скористатися послугою прискореного сушіння."
                }
            },
            {
                "@type": "Question",
                "name": "Чи безпечні засоби для чищення для дітей і домашніх тварин?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Так. Ми використовуємо сертифіковані гіпоалергенні засоби, безпечні для дітей і домашніх тварин. Після чищення рекомендуємо користуватися меблями лише після повного висихання."
                }
            },
            {
                "@type": "Question",
                "name": "Як підготувати меблі до чищення?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Достатньо прибрати з меблів подушки, пледи та інші речі. Переставляти або пересувати меблі не потрібно — усім іншим займуться наші спеціалісти."
                }
            }
        ]
    }
