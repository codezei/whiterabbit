
section.reviews#reviews.block.section
    .container.section__container
        .section__header.section__header--fill.decor-lavender
            .section__header-top
                h2.section__title.text-uppercase.mb-0 Opinie
                .section__navigation
                    .swiper-navigation
                        button(type="button" aria-label="Poprzednia kategoria").reviews-button-prev.btn.btn-primary-outline.btn-small.btn-circle
                            span.sr-only Poprzednia kategoria
                            svg.bi.bi-chevron-left.d-block(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16")
                                path(fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0")
                        button(type="button" aria-label="Następna kategoria").reviews-button-next.btn.btn-primary-outline.btn-small.btn-circle
                            span.sr-only Następna kategoria
                            svg.bi.bi-chevron-right.d-block(xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16")
                                path(fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708")
            .section__header-bottom
                .section__subtitle.h6.text-light.mb-0.text-primary ✦ Opinie klientów, którzy skorzystali z naszych usług
        .section__body.js-observe
            nav.categories-navigation(aria-label="Kategorie czyszczenia")
                .categories-navigation-swiper
                    .swiper-wrapper
                        .swiper-slide
                            button.btn.btn-secondary-outline.btn-small.btn-pillow.category-btn(type="button")
                                span.category-btn__text Tapicerka meblowa
                        .swiper-slide
                            button.btn.btn-secondary-outline.btn-small.btn-pillow.category-btn(type="button")
                                span.category-btn__text Materace
                        .swiper-slide
                            button.btn.btn-secondary-outline.btn-small.btn-pillow.category-btn(type="button")
                                span.category-btn__text Dywany
                        .swiper-slide
                            button.btn.btn-secondary-outline.btn-small.btn-pillow.category-btn(type="button")
                                span.category-btn__text Tapicerka samochodowa
                        .swiper-slide
                            button.btn.btn-secondary-outline.btn-small.btn-pillow.category-btn(type="button")
                                span.category-btn__text Okna
            .categories-content
                .swiper.categories-content-swiper.reviews-swiper(data-disallow-touch="true" data-next-selector=".reviews-button-next" data-prev-selector=".reviews-button-prev")
                    .swiper-wrapper
                        .swiper-slide.h-auto
                            article
                                h3.h2 Opinie o praniu tapicerki meblowej&nbsp;
                                    include cities
                                include reviews/reviews-furniture
                        .swiper-slide.h-auto
                            article
                                h3.h2 Opinie o czyszczeniu materacy&nbsp;
                                    include cities
                                include reviews/reviews-mattress
                        .swiper-slide.h-auto
                            article
                                h3.h2 Opinie o praniu dywanów&nbsp;
                                    include cities
                                include reviews/reviews-carpet
                        .swiper-slide.h-auto
                            article
                                h3.h2 Opinie o czyszczeniu tapicerki samochodowej&nbsp;
                                    include cities
                                include reviews/reviews-salon
                        .swiper-slide.h-auto
                            article
                                h3.h2 Opinie o myciu okien&nbsp;
                                    include cities
                                include reviews/reviews-window
