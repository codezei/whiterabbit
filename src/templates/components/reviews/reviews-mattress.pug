.row.row-cols-sm-2.row-cols-md-3.row-cols-lg-4
    .col.animate-fade-in(style="--i: 0;")
        .review.card.card-primary-outline.card-leaf
            .review__header
                img.review__ava(src="img/rabbit-ava.png", alt="")
                .review__user
                    h4.h6.review__name
                        span Ewa M.
                        //- span Ewa Mazur
                    .reviews__city.text-secondary
                        svg.icon.icon-right(width="16" height="16")
                            use(href="#geo")
                        | Warszawa
            .review__meta
                .rating.review__rating(style="--star-rating: 5;")
                .review__date.text-muted.date-8 12.05.2025
            p.review__text Zamówiłam w WhiteRabbit pranie materaca dwuosobowego i jestem bardzo zadowolona z efektu. Materac jest odświeżony, zniknęły zabrudzenia i znów przyjemnie się z niego korzysta. Polecam.
            .review__toggle
                span.in-active-none
                    svg.icon.icon-right(width="16" height="16")
                        use(href="#eye")
                    | Pokaż więcej
                span.in-inactive-none
                    svg.icon.icon-right(width="16" height="16")
                        use(href="#eye-close")
                    | Pokaż mniej
