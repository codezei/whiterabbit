.row.row-cols-sm-2.row-cols-md-3.row-cols-lg-4
    .col.animate-fade-in(style="--i: 0;")
        .review.card.card-primary-outline.card-leaf
            .review__header
                h4.h6.review__name
                    span Agnieszka Wysocka
                .rating.review__rating(style="--star-rating: 5;")
            p.review__text Zamówiłam w WhiteRabbit pranie dużego dywanu w salonie i efekt jest naprawdę świetny. Kolory stały się wyraźniejsze, zniknęły zabrudzenia, a dywan wygląda dużo świeżej. Bardzo polecam.
            .review__toggle
                span.in-active-none
                    svg.icon.icon-right(width="16" height="16")
                        use(href="#eye")
                    | Pokaż więcej
                span.in-inactive-none
                    svg.icon.icon-right(width="16" height="16")
                        use(href="#eye-close")
                    | Pokaż mniej
